<Page
    x:Class="Sorvil.Views.ReaderPdfPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <FlipView x:Name="PagesFlipView" Grid.Row="0" SelectionChanged="PagesFlipView_SelectionChanged">
            <FlipView.ItemTemplate>
                <DataTemplate>
                    <ScrollViewer ZoomMode="Enabled"
                                  MinZoomFactor="1"
                                  MaxZoomFactor="4"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Image Source="{Binding Image, Mode=OneWay}" Stretch="Uniform" />
                    </ScrollViewer>
                </DataTemplate>
            </FlipView.ItemTemplate>
        </FlipView>

        <TextBlock x:Name="PageIndicatorText"
                   Grid.Row="1"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,8" />

        <ProgressRing x:Name="LoadingRing"
                      Grid.RowSpan="2"
                      IsActive="False"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
    </Grid>
</Page>
