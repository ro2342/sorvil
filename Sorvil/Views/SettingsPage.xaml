<Page
    x:Class="Sorvil.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Pivot Title="Ajustes" Margin="12,12,12,0">
        <PivotItem Header="Servidor">
            <ScrollViewer>
                <StackPanel Padding="4,16,4,20">
                    <TextBlock Text="Endereço do Calibre-Web" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4" />
                    <TextBox x:Name="BaseUrlBox"
                             PlaceholderText="http://192.168.1.10:8083"
                             InputScope="Url"
                             Margin="0,0,0,16" />

                    <TextBlock Text="Usuário" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4" />
                    <TextBox x:Name="UsernameBox" Margin="0,0,0,16" />

                    <TextBlock Text="Senha" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TestButton" Content="Testar conexão" Click="TestButton_Click" Margin="0,0,12,0" />
                        <Button x:Name="SaveButton" Content="Salvar" Click="SaveButton_Click" />
                    </StackPanel>

                    <ProgressRing x:Name="TestProgress" IsActive="False" Width="24" Height="24" HorizontalAlignment="Left" Margin="0,16,0,0" />
                    <TextBlock x:Name="StatusText"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="0,16,0,0" />
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <PivotItem Header="Aparência">
            <StackPanel Padding="4,16,4,20">
                <TextBlock Text="Tema" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,8" />
                <RadioButton x:Name="ThemeAutoRadio"
                             Content="Automático (seguir o sistema)"
                             GroupName="Theme"
                             Tag="auto"
                             Checked="ThemeRadio_Checked" />
                <RadioButton x:Name="ThemeLightRadio"
                             Content="Claro"
                             GroupName="Theme"
                             Tag="light"
                             Checked="ThemeRadio_Checked" />
                <RadioButton x:Name="ThemeDarkRadio"
                             Content="Escuro"
                             GroupName="Theme"
                             Tag="dark"
                             Checked="ThemeRadio_Checked" />
            </StackPanel>
        </PivotItem>

        <PivotItem Header="Sobre">
            <StackPanel Padding="4,16,4,20">
                <TextBlock x:Name="VersionText" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,16" />

                <Button Content="Checar atualização" Click="CheckUpdate_Click" HorizontalAlignment="Left" Margin="0,0,0,12" />

                <TextBlock x:Name="UpdateStatusText"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <Button x:Name="UpdateActionButton"
                        Content="Instalar"
                        Click="UpdateActionButton_Click"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed"
                        Margin="0,0,0,12" />

                <ProgressBar x:Name="UpdateProgress" Minimum="0" Maximum="100" Visibility="Collapsed" />
            </StackPanel>
        </PivotItem>
    </Pivot>
</Page>
