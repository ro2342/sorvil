<Page
    x:Class="Sorvil.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="20,24,20,20">
            <TextBlock Text="Sorvil" Style="{StaticResource TitleTextBlockStyle}" />

            <Border x:Name="SetupHintBorder"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Configure o seu Calibre-Web"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Ainda não há um servidor configurado. Vá em Ajustes → Servidor pra conectar."
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,12" />
                    <Button Content="Abrir Ajustes" Click="OpenSettings_Click" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="ReadyText"
                       Text="Capas dos livros e continuação de leitura aparecem aqui."
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"
                       Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</Page>
