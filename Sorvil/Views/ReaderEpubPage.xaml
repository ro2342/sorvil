<Page
    x:Class="Sorvil.Views.ReaderEpubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <WebView x:Name="ContentWebView" Margin="16,10" SizeChanged="ContentWebView_SizeChanged" />

            <!-- Zonas de toque por cima do WebView: esquerda volta página,
                 direita avança, meio alterna a barra inferior — o mesmo
                 padrão de Kindle/Freda. Ficam por cima de propósito: assim
                 o toque nunca vira rolagem/seleção nativa do WebView, só
                 controla a paginação via script. -->
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" Tapped="PreviousZone_Tapped" />
                <Border Grid.Column="1" Background="Transparent" Tapped="ToggleChrome_Tapped" />
                <Border Grid.Column="2" Background="Transparent" Tapped="NextZone_Tapped" />
            </Grid>
        </Grid>

        <ProgressRing x:Name="LoadingRing"
                      Grid.RowSpan="2"
                      IsActive="False"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <Grid x:Name="BottomBar"
              Grid.Row="1"
              Padding="12,8"
              Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
              IsHitTestVisible="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="ReaderSettingsButton" Grid.Column="0" Content="Aa" Click="ReaderSettings_Click" Margin="0,0,8,0" />
            <Button Grid.Column="1" Content="Anterior" Click="PreviousButton_Click" />
            <TextBlock x:Name="ChapterIndicatorText"
                       Grid.Column="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
            <Button Grid.Column="3" Content="Próximo" Click="NextButton_Click" />
        </Grid>
    </Grid>
</Page>
