<Page
    x:Class="Sorvil.Views.ReaderEpubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="SorvilGreenBrush" Color="#FF5DA130" />
        <SolidColorBrush x:Key="SorvilGreenDarkBrush" Color="#FF4C8524" />
        <SolidColorBrush x:Key="SorvilCharcoalBrush" Color="#FF2C2C2C" />

        <!-- Botão liso (sem chrome arredondado nem fundo no estado normal)
             pros ícones da barra verde e das barras de leitura — o app já
             usa esse padrão de template simplificado no MainPage. -->
        <Style x:Key="ReaderIconButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho verde, sempre visível (não some ao tocar) — igual
             ao apphdr da página de livro no mockup: hambúrguer abre o
             índice de capítulos, título do livro ao lado. -->
        <Grid Grid.Row="0" Background="{StaticResource SorvilGreenBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="ChapterDrawerButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                <FontIcon Glyph="&#xE700;" Foreground="White" FontSize="20" />
            </Button>
            <TextBlock x:Name="HeaderBookTitleText"
                       Grid.Column="1"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="16"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="4,0,16,0" />
        </Grid>

        <Grid Grid.Row="1">
            <WebView x:Name="ContentWebView" SizeChanged="ContentWebView_SizeChanged" />

            <!-- "Brilho": um overlay preto semitransparente por cima de
                 tudo, com a Opacity controlada por um slider — não mexe
                 em brilho de hardware nenhum (evita depender de mais uma
                 API de plataforma, depois do susto com a extensão da
                 StatusBar). -->
            <Border x:Name="DimOverlay" Background="Black" Opacity="0" IsHitTestVisible="False" />

            <!-- Zonas de toque por cima do WebView: esquerda volta página,
                 direita avança, meio alterna as barras de leitura — o
                 mesmo padrão de Kindle/Freda. Ficam por cima de propósito:
                 assim o toque nunca vira rolagem/seleção nativa do
                 WebView, só controla a paginação via script. -->
            <Grid x:Name="GestureZoneGrid"
                  Background="Transparent"
                  ManipulationMode="System"
                  ManipulationStarted="GestureZoneGrid_ManipulationStarted"
                  ManipulationDelta="GestureZoneGrid_ManipulationDelta"
                  ManipulationCompleted="GestureZoneGrid_ManipulationCompleted">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" Tapped="PreviousZone_Tapped" />
                <Border Grid.Column="1" Background="Transparent" Tapped="ToggleChrome_Tapped" />
                <Border Grid.Column="2" Background="Transparent" Tapped="NextZone_Tapped" />
            </Grid>

            <!-- Barra de cima (some por padrão, aparece ao tocar no meio):
                 Voltar ao Início à esquerda, Aa/brilho/gestos à direita —
                 igual ao toolbar-top do mockup. -->
            <Grid x:Name="TopBar"
                  VerticalAlignment="Top"
                  Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                  Padding="8,8"
                  Opacity="0"
                  IsHitTestVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="BackToHome_Click" HorizontalAlignment="Left" Style="{StaticResource ReaderIconButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE80F;" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Voltar ao Início" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="TypographyButton" Grid.Column="1" Content="Aa" Click="TypographyButton_Click" FontWeight="Bold" Style="{StaticResource ReaderIconButtonStyle}" />
                <Button x:Name="BrightnessButton" Grid.Column="2" Click="BrightnessButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE706;" FontSize="17" />
                </Button>
                <Button x:Name="GestureSettingsButton" Grid.Column="3" Click="GestureSettingsButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="17" />
                </Button>
            </Grid>
        </Grid>

        <ProgressRing x:Name="LoadingRing"
                      Grid.RowSpan="2"
                      IsActive="False"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,0,0,36" />

        <!-- Status de carregamento/erro — independente da barra de baixo
             (que some por padrão), pra sempre aparecer durante o primeiro
             carregamento do livro, antes de qualquer toque na tela. -->
        <TextBlock x:Name="LoadingStatusText"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="24,84,24,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />

        <!-- Barra de baixo (some por padrão, aparece ao tocar no meio):
             fileira de ícones (fechar barra / índice / busca / próximo
             capítulo) + legenda com título do livro e capítulo atual —
             igual ao toolbar-bottom do mockup. -->
        <StackPanel x:Name="BottomBar"
                    Grid.Row="1"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    Opacity="0"
                    IsHitTestVisible="False">
            <Grid Padding="4,8,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="CollapseBar_Click" Style="{StaticResource ReaderIconButtonStyle}" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE76B;" FontSize="16" />
                </Button>
                <Button x:Name="TocButton" Grid.Column="1" Click="ChapterDrawerButton_Click" Style="{StaticResource ReaderIconButtonStyle}" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE700;" FontSize="16" />
                </Button>
                <Button Grid.Column="2" Click="SearchButton_Click" Style="{StaticResource ReaderIconButtonStyle}" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE721;" FontSize="16" />
                </Button>
                <Button Grid.Column="3" Click="NextButton_Click" Style="{StaticResource ReaderIconButtonStyle}" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE76C;" FontSize="16" />
                </Button>
            </Grid>
            <StackPanel HorizontalAlignment="Center" Margin="0,2,0,8">
                <TextBlock x:Name="BottomCaptionBookText"
                           FontSize="11"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="280" />
                <TextBlock x:Name="BottomCaptionChapterText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="280"
                           Margin="0,1,0,0" />
            </StackPanel>
            <ProgressBar x:Name="ReadingProgressBar" Minimum="0" Maximum="100" Height="3" />
        </StackPanel>

        <!-- Índice de capítulos: painel de tela cheia (não um Flyout
             pequeno) que desliza por cima de tudo, igual ao chapter-drawer
             do mockup — cabeçalho verde igual ao da página de leitura +
             lista escura com o capítulo atual destacado. -->
        <Grid x:Name="ChapterDrawer" Grid.RowSpan="2" Background="{StaticResource SorvilCharcoalBrush}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource SorvilGreenBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ChapterDrawerButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE700;" Foreground="White" FontSize="20" />
                </Button>
                <TextBlock x:Name="DrawerBookTitleText"
                           Grid.Column="1"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="16"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="4,0,16,0" />
            </Grid>
            <ListView x:Name="ChapterDrawerList"
                      Grid.Row="1"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="ChapterDrawerList_ItemClick" />
        </Grid>
    </Grid>
</Page>
