<Page
    x:Class="Sorvil.Views.ReaderEpubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="SorvilGreenBrush" Color="#FF5DA130" />
        <SolidColorBrush x:Key="SorvilGreenActiveBrush" Color="#FF326019" />
        <SolidColorBrush x:Key="SorvilLightIconBrush" Color="#FFEEEEEE" />
        <SolidColorBrush x:Key="SorvilDimIconBrush" Color="#FFDDDDDD" />

        <!-- Botão liso (sem chrome arredondado nem fundo no estado normal),
             reaproveitado pelos ícones de todas as barras/painéis escuros
             e pelo cabeçalho claro do índice. -->
        <Style x:Key="ReaderIconButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="4,9" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="#FF555555" />
            <Setter Property="Foreground" Value="#FFEEEEEE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#FF4A4A4A" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <!-- Sem WebView: cada "página" é um RichTextBlock (a primeira) ou
             RichTextBlockOverflow (as seguintes), encadeados em tempo de
             execução — técnica nativa padrão do UWP pra texto fluido
             paginado, sem depender de CSS/motor de renderização nenhum.
             Só um fica visível por vez (Visibility), os outros ficam
             prontos por baixo pra virar página ser instantâneo. -->
        <Grid x:Name="PagesHost" SizeChanged="PagesHost_SizeChanged" Background="White" />

        <!-- "Brilho": um overlay preto semitransparente por cima de tudo,
             com a Opacity controlada por um slider — não mexe em brilho de
             hardware nenhum (evita depender de mais uma API de plataforma,
             depois do susto com a extensão da StatusBar). -->
        <Border x:Name="DimOverlay" Background="Black" Opacity="0" IsHitTestVisible="False" />

        <!-- Zonas de toque por cima do WebView: esquerda/direita viram
             página (só se "toque nos cantos" estiver ligado nos gestos),
             meio alterna a barra de leitura. -->
        <Grid x:Name="GestureZoneGrid"
              Background="Transparent"
              ManipulationMode="System"
              ManipulationStarted="GestureZoneGrid_ManipulationStarted"
              ManipulationDelta="GestureZoneGrid_ManipulationDelta"
              ManipulationCompleted="GestureZoneGrid_ManipulationCompleted">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="Transparent" Tapped="PreviousZone_Tapped" />
            <Border Grid.Column="1" Background="Transparent" Tapped="ReaderArea_Tapped" />
            <Border Grid.Column="2" Background="Transparent" Tapped="NextZone_Tapped" />
        </Grid>

        <ProgressRing x:Name="LoadingRing"
                      IsActive="False"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,0,0,36" />

        <TextBlock x:Name="LoadingStatusText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="24,84,24,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />

        <!-- Barra de cima escura + painéis de fonte/tema/gestos, anexados
             logo abaixo dela (não um Flyout por cima do texto) — some por
             padrão (modo imersivo), aparece ao tocar no meio da tela. -->
        <!-- RequestedTheme="Dark" força Slider/ToggleSwitch/Button a
             usarem pincéis escuros do sistema em vez de herdar o tema
             claro/escuro do dispositivo — sem isso, num aparelho com tema
             Claro os controles padrão (trilha do slider, chave do
             ToggleSwitch) ficavam com cores de tema claro por cima do
             fundo escuro fixo destas barras, parecendo fora do lugar. -->
        <StackPanel x:Name="TopChrome" RequestedTheme="Dark" VerticalAlignment="Top" Opacity="0" IsHitTestVisible="False">
            <Grid x:Name="ToolbarTop" Background="#FF3A3A3A" Padding="10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="BackToHome_Click" HorizontalAlignment="Left" Style="{StaticResource ReaderIconButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="{StaticResource SorvilLightIconBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Voltar ao Início" FontSize="13" Foreground="{StaticResource SorvilLightIconBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="TypographyButton" Grid.Column="1" Click="TypographyButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <TextBlock x:Name="AaText" Text="Aa" FontWeight="Bold" Foreground="{StaticResource SorvilLightIconBrush}" />
                </Button>
                <Button x:Name="BrightnessButton" Grid.Column="2" Click="BrightnessButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon x:Name="BrightnessIcon" Glyph="&#xE706;" FontSize="17" Foreground="{StaticResource SorvilLightIconBrush}" />
                </Button>
                <Button x:Name="GestureSettingsButton" Grid.Column="3" Click="GestureSettingsButton_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon x:Name="GestureIcon" Glyph="&#xE713;" FontSize="17" Foreground="{StaticResource SorvilLightIconBrush}" />
                </Button>
            </Grid>

            <StackPanel x:Name="FontPanel" Background="#FF363636" Padding="18,16" Visibility="Collapsed">
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fonte" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button x:Name="FontFamilyButton" Grid.Column="2" Click="FontFamilyButton_Click" Padding="10,6" Background="Transparent" BorderBrush="#FF666666" BorderThickness="1">
                        <TextBlock x:Name="FontFamilyText" FontSize="12.5" Foreground="{StaticResource SorvilLightIconBrush}" />
                    </Button>
                </Grid>
                <TextBlock Text="Tamanho da fonte" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Slider x:Name="FontSizeSlider" Minimum="70" Maximum="350" StepFrequency="10" Margin="0,0,0,14" ValueChanged="FontSizeSlider_ValueChanged" />
                <TextBlock Text="Espaçamento entre linhas" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Slider x:Name="LineSpacingSlider" Minimum="1.0" Maximum="2.5" StepFrequency="0.1" Margin="0,0,0,14" ValueChanged="LineSpacingSlider_ValueChanged" />
                <TextBlock Text="Margens" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Slider x:Name="MarginSlider" Minimum="8" Maximum="48" StepFrequency="2" Margin="0,0,0,14" ValueChanged="MarginSlider_ValueChanged" />
                <TextBlock Text="Alinhamento" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel x:Name="JustificationRow" Orientation="Horizontal" />
            </StackPanel>

            <StackPanel x:Name="ThemePanel" Background="#FF363636" Padding="18,16" Visibility="Collapsed">
                <TextBlock Text="Brilho da tela" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Slider x:Name="DimSlider" Minimum="0" Maximum="80" Margin="0,0,0,18" ValueChanged="DimSlider_ValueChanged" />
                <TextBlock Text="Tema do livro" FontSize="12.5" Foreground="#FFBBBBBB" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel x:Name="ThemeRow" Orientation="Horizontal" />
            </StackPanel>

            <StackPanel x:Name="GesturesPanel" Background="#FF363636" Padding="18,4" Visibility="Collapsed" />
        </StackPanel>

        <!-- Índice: cabeçalho no estilo da Home (largura cheia) + lista de
             capítulos encostada à esquerda ocupando ~62% da largura,
             deixando o resto do conteúdo visível ao lado. -->
        <Grid x:Name="IndexOverlay" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#FFECECEC">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="CloseIndex_Click" Width="48" Height="48" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE700;" Foreground="White" FontSize="20" />
                </Button>
                <TextBlock x:Name="IndexHeaderTitleText"
                           Grid.Column="1"
                           Foreground="#FF1A1A1A"
                           FontWeight="SemiBold"
                           FontSize="16"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="4,0,16,0" />
            </Grid>
            <Grid Grid.Row="1" RequestedTheme="Dark">
                <!-- Fecha o índice ao tocar fora da lista (na parte do
                     conteúdo do livro que continua visível ao lado) —
                     mesmo comportamento de "tocar fora fecha" que a gaveta
                     de navegação da Home já tinha. Fica atrás da lista no
                     Grid (declarada primeiro), então o toque num capítulo
                     é capturado pela lista antes de chegar aqui. -->
                <Border Background="Transparent" Tapped="IndexDismissArea_Tapped" />
                <ListView x:Name="ChapterDrawerList"
                          HorizontalAlignment="Left"
                          Background="#FF2C2C2C"
                          SelectionMode="None" />
            </Grid>
        </Grid>

        <!-- Barra de baixo escura: legenda, scrubber (visual) e a fileira
             de ícones (índice / capítulo atual ou busca / busca) — só
             aparece junto com a de cima quando nenhum painel/índice está
             aberto. -->
        <StackPanel x:Name="BottomBar" RequestedTheme="Dark" VerticalAlignment="Bottom" Background="#FF3A3A3A" Opacity="0" IsHitTestVisible="False" Padding="14,10,14,8">
            <TextBlock x:Name="BottomCaptionText"
                       FontSize="11"
                       Foreground="#FFBBBBBB"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="320"
                       Margin="0,0,0,8" />
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ScrubBack_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE892;" FontSize="14" Foreground="{StaticResource SorvilDimIconBrush}" />
                </Button>
                <Slider x:Name="ScrubberSlider" Grid.Column="1" Minimum="0" Maximum="100" IsThumbToolTipEnabled="False" />
                <Button Grid.Column="2" Click="ScrubForward_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE893;" FontSize="14" Foreground="{StaticResource SorvilDimIconBrush}" />
                </Button>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="OpenIndex_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE700;" FontSize="16" Foreground="{StaticResource SorvilDimIconBrush}" />
                </Button>
                <TextBlock x:Name="TbCenterLabel"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SorvilLightIconBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBox x:Name="TbSearchInput"
                         Grid.Column="1"
                         Visibility="Collapsed"
                         PlaceholderText="Pesquisar no livro..."
                         Margin="8,0" />
                <Button Grid.Column="2" Click="ToggleSearch_Click" Style="{StaticResource ReaderIconButtonStyle}">
                    <FontIcon Glyph="&#xE721;" FontSize="16" Foreground="{StaticResource SorvilDimIconBrush}" />
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
