<Application
    x:Class="Sorvil.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <!-- Estilos compartilhados entre páginas nativas, sem paleta de cor
             customizada — só agrupamento visual reaproveitando os brushes
             de tema padrão do próprio UWP (claro/escuro/cor de destaque). -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- Linha fina separando seções dentro de uma mesma tela/aba. -->
        <Style x:Key="SectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,20,0,20" />
            <Setter Property="Background" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
        </Style>

        <!-- Sem x:Key: aplica implicitamente a QUALQUER PivotHeaderItem do
             app (abas de Ajustes) — nome de aba em fonte pequena, igual ao
             "General/Privacy statement" do Settings nativo da Microsoft. -->
        <Style TargetType="PivotHeaderItem">
            <Setter Property="FontSize" Value="16" />
        </Style>
    </Application.Resources>

</Application>
